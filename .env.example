# Copy to .env in this directory.
GEMINI_API_KEY=

# Suppress noisy GET /api/compile/status and /api/health from the access log (default).
# Set to `all` to log every request line to the terminal.
# DGENE_HTTP_LOG=all

# Extra compile-job stderr lines from server.py ([oge/server HH:MM:SS] …)
# DGENE_SERVER_DEBUG=1

# Gemini API / retry traces ([oge/infer] on stderr): DGENE_GEMINI_DEBUG=1
# iGEM RAG retrieval traces (extra hit lists): DGENE_RAG_DEBUG=1 or DGENE_DEBUG=1
# (Every compile already logs chroma queries, ALIAS HIT, slot summaries, bp before/after on stderr.)

# RAG cosine threshold: default 0.6. Promoters use ``DGENE_RAG_MIN_SIM_PROMOTER`` (default 0.80) to avoid weak ``pL*`` collisions.
# DGENE_RAG_MIN_SIM=0.6
# DGENE_RAG_MIN_SIM_PROMOTER=0.80

DGENE_GEMINI_MODEL=gemma-4-31b-it

# Registry corpus JSONL (default ``data/igem_dataset.jsonl`` under the repo root).
# DGENE_IGEM_JSONL=

# Seconds per HTTP request (default 600). Increase if you see "read operation timed out".
# DGENE_GEMINI_HTTP_TIMEOUT=900

# Max output tokens per candidate (default 8192 — enough for typical multi‑part DNA + reasoning;
# very high caps let the model ramble instead of emitting </circuit>). Raise (e.g. 16384–32768)
# for unusually long single-piece constructs. For live demos consider 2048–4096 to cap bullets.
# DGENE_GEMINI_MAX_OUTPUT=8192

# While Google is generating, append a live trace line every N seconds (default 15). Set 0 to disable.
# Applies to both one-shot and SSE streaming so the UI does not look frozen.
# DGENE_GEMINI_HTTP_HEARTBEAT_SEC=15

# Use streamGenerateContent (SSE) for live partial text in the UI during compile jobs (default on).
# Set 0 to fall back to one-shot generateContent (no live token preview).
# DGENE_GEMINI_STREAM=1
# When SSE is on, stop reading the HTTP body once </circuit> + parse succeeds (default on; saves tail latency).
# DGENE_GEMINI_STREAM_EARLY_CLOSE=1

# Minimum DNA length (bp) accepted when parsing `<channel|>` tail (default 12). Lower if tiny constructs fail.
# DGENE_MIN_PARSE_DNA_LEN=12

# Run candidate generations in parallel (default on). Set 0 to serialize (easier debugging).
# DGENE_GEMINI_PARALLEL=1
# Concurrent hosted candidate calls (default 4 — matches n=4). Lower if you hit 429 / flaky TLS.
# DGENE_GEMINI_MAX_WORKERS=4

# Compile pipeline:
# circuit_synth (default) = boolean intent → verified topology + iGEM DNA → truth-table check;
#   extra candidate slots use RAG-first. Unlocks: BUF/NOT/AND/OR/NAND/NOR over catalog inducers.
# rag_first = intent → Chroma menu → Gemma part order → registry DNA only (no logic proof).
# legacy = channel-tagged DNA from the model + post-hoc RAG substitution.
# DGENE_COMPILE_MODE=circuit_synth
# Top Chroma hits per retrieval query in rag_first (default 15).
# DGENE_RAG_FIRST_TOP_K=15
# Max BBa IDs in ORDERED_PART_LIST (default 48; typical construct 6–24).
# DGENE_RAG_FIRST_MAX_PARTS=48
# Compiler max output tokens (default 3072 — keeps responses short).
# DGENE_RAG_FIRST_COMPILER_MAX_TOKENS=3072
# Max characters / sentences for the left-panel reasoning summary (defaults 1400 / 7).
# DGENE_RAG_FIRST_REASONING_CHARS=1400
# DGENE_RAG_FIRST_REASONING_SENTENCES=7

# Prepends deterministic 4-part cassette for AND/OR/BUF when Gemma emits gate/input_analytes (+ reporter).
# DGENE_SLOT_TEMPLATE=1
# Promoter cosine floor (embedding); lower if retrieval refuses borderline composites.
# DGENE_SLOT_TEMPLATE_MIN_SIM=0.52
# Skip absurdly long promoters (composite devices); lower for stricter demos.
# DGENE_SLOT_TEMPLATE_MAX_PROMOTER_BP=4000
# Wrap slot-template cassette in the same E. coli RFC10 backbone as circuit_synth (ori+CmR+MCS).
# DGENE_SLOT_TEMPLATE_EMBED_BACKBONE=1

# auto | gemini | gguf — must resolve to API key OR valid DGENE_GGUF_PATH (offline mock mode removed).
# DGENE_INFERENCE=auto

# Local Gemma 4 quantized checkpoint (.gguf from Hugging Face or your mirror). You host inference.
# DGENE_GGUF_PATH=/absolute/path/to/opengeneedit-gemma4.ft.gguf
# If GEMINI_* is still set but you want GGUF: DGENE_INFERENCE=gguf
# JSON / intent / RAG-first compiler calls use ``generate_text_gemma4_custom`` on GGUF too (no API).
# Cap for those completions (default 8192; bounded by ``DGENE_GGUF_CTX`` inside inference).
# DGENE_GGUF_CHAT_MAX_TOKENS=8192

# --- NCBI Entrez (optional CDS fallback when iGEM RAG does not verify a gene slot)
# Free API key: https://www.ncbi.nlm.nih.gov/account/settings/ — raises rate limit to 10 req/s.
# Or: DGENE_NCBI_API_KEY=
# Polite-use contact (recommended): DGENE_NCBI_EMAIL=you@example.com
# Disable Entrez fallback: DGENE_NCBI=0
# Entrez on **Promoter** slots (default off): Gene fetch returns CDS/locus, not cis-regulatory DNA.
# DGENE_NCBI_PROMOTER_SLOTS=0
# Default organism search order (comma-separated scientific names):
# DGENE_NCBI_ORGANISMS=Pseudomonas aeruginosa,Escherichia coli

# --- Saved design URLs (bookmarkable workspace after compile; ``.design_snapshots/*.json``, gitignored)
# Disable writing/loading snapshots: DGENE_SNAPSHOTS=0

# Optional second Gemma pass: PhD-style prose review of ordered BBa list + user brief (extra API cost).
# DGENE_EXPERT_REVIEW=1
